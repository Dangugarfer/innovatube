# Configuración del Servidor
PORT=5000
NODE_ENV=development

# Configuración de Base de Datos
MONGO_URI=mongodb://localhost:27017/innovatube

# Autenticación JWT
JWT_SECRET=tu_jwt_secreto_super_seguro_cambialo
JWT_EXPIRES_IN=30d

# Configuración del Cliente (CORS)
CLIENT_URL=http://localhost:4200

# Google reCAPTCHA v2 (Sección Registro)
# Opcional en desarrollo. Si no se define, el backend saltará la verificación.
RECAPTCHA_SECRET_KEY=TU_RECAPTCHA_SECRET_KEY

# YouTube Data API v3 (Sección Búsqueda)
# Opcional en desarrollo. Si no se define o falla, el backend responderá con datos simulados (mock).
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY

# Servidor SMTP (Nodemailer - Recuperación de contraseña)
# Si no se configura, el servidor imprimirá el enlace de recuperación en la consola/logs.
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=tu_usuario_smtp
SMTP_PASS=tu_contrasena_smtp
